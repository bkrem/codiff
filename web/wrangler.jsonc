{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "codiff",
  "compatibility_date": "2026-07-16",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "routes": [
    {
      "pattern": "codiff.dev",
      "custom_domain": true,
    },
  ],
}
